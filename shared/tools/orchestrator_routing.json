{
  "orchestrator": {
    "name": "orchestrator",
    "model": "default",
    "enabled": true
  },
  "routing": {
    "tui": {
      "channel": "tui",
      "primaryAgent": "orchestrator",
      "fallbackAgent": "orchestrator",
      "priority": 10
    },
    "discord": {
      "channel": "discord",
      "primaryAgent": "orchestrator",
      "fallbackAgent": "orchestrator",
      "priority": 20
    }
  },
  "agents": {
    "parlei_speak_er": {
      "enabled": true,
      "required": true,
      "model": "default"
    },
    "parlei_plan_er": {
      "enabled": true,
      "required": false,
      "model": "default"
    },
    "parlei_task_er": {
      "enabled": true,
      "required": false,
      "model": "default"
    }
  },
  "model_override": {
    "enabled": false,
    "strategy": "dynamic",
    "rules": {
      "fast_channel": {
        "channel": "tui",
        "default_model": "anthropic/claude-3.5-sonnet"
      },
      "complex_tasks": {
        "task_type": "complex",
        "default_model": "anthropic/claude-3-5-opus"
      }
    }
  },
  "routes": [
    {
      "from": "tui",
      "to": "parlei_speak_er",
      "condition": "message_type == 'simple_request'"
    },
    {
      "from": "discord",
      "to": "parlei_speak_er",
      "condition": "message_type == 'simple_request' OR (message_type == 'thread_reply' AND context == 'parlei')"
    },
    {
      "from": "tui",
      "to": "parlei_plan_er",
      "condition": "message_type == 'complex_request' AND requires_planning == true"
    },
    {
      "from": "discord",
      "to": "parlei_plan_er",
      "condition": "message_type == 'complex_request' AND requires_planning == true"
    },
    {
      "from": "any",
      "to": "parlei_task_er",
      "condition": "state == 'planning_complete' AND requires_execution == true"
    }
  ],
  "lateral_grants": {
    "allowed_transitions": [
      {
        "from": "parlei_speak_er",
        "to": "parlei_plan_er"
      },
      {
        "from": "parlei_speak_er",
        "to": "parlei_task_er"
      },
      {
        "from": "parlei_plan_er",
        "to": "parlei_task_er"
      }
    ],
    "default_duration": "single_session"
  }
}